Checks: >
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  clang-diagnostic-*,
  concurrency-*,
  misc-*,
  modernize-*,
  performance-*,
  readability-*,
  -readability-braces-around-statements
  -readability-isolate-declaration

WarningsAsErrors: >
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  clang-diagnostic-*,
  concurrency-*,
  performance-*

CheckOptions:
  - key: modernize-use-override.IgnoreDestructors
    value: true
  - key: misc-const-correctness.AnalyzeValues
    value: false
  - key: readability-identifier-length.MinimumVariableNameLength
    value: 1
HeaderFilterRegex: ".*"
FormatStyle: file
